<section class="why-choose section-padding" style="background: {{ section.settings.background_color }};">
  <div class="container">
    <div class="section-header section-header--center">
      {% if section.settings.eyebrow != blank %}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="section-title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="why-choose__grid">
      {% for block in section.blocks %}
        <div class="why-choose__item" {{ block.shopify_attributes }}>
          <div class="why-choose__icon-wrap">
            {% if block.settings.icon_image %}
              <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="{{ block.settings.title }}" width="60" height="60">
            {% else %}
              <div class="why-choose__icon">
                {% case block.settings.icon %}
                  {% when 'bee' %}
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2.5 4 7v10l8 4.5 8-4.5V7l-8-4.5z"/>
                      <path d="M12 2.5v9"/>
                      <path d="m4 7 8 4.5"/>
                      <path d="m20 7-8 4.5"/>
                    </svg>
                  {% when 'mountain' %}
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m8 3 4 8 5-5 5 15H2L8 3z"/>
                    </svg>
                  {% when 'lab' %}
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a2 2 0 0 0 1.8 2.95h10.96a2 2 0 0 0 1.8-2.95L14.21 10.423a2 2 0 0 1-.21-.896V2"/>
                      <path d="M8 2h8"/>
                      <path d="M14 15a4 4 0 1 1-8 0"/>
                    </svg>
                  {% when 'heart' %}
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"/>
                    </svg>
                  {% when 'truck' %}
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/>
                      <path d="M15 18H9"/>
                      <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/>
                      <circle cx="17" cy="18" r="2"/>
                      <circle cx="7" cy="18" r="2"/>
                    </svg>
                  {% when 'leaf' %}
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
                      <path d="M2 22 12 12"/>
                    </svg>
                  {% else %}
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <path d="M12 8v4l3 3"/>
                    </svg>
                {% endcase %}
              </div>
            {% endif %}
          </div>
          <h3 class="why-choose__title">{{ block.settings.title }}</h3>
          <p class="why-choose__text">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {"value": "bee", "label": "Bee"},
            {"value": "mountain", "label": "Mountain"},
            {"value": "lab", "label": "Lab / Science"},
            {"value": "heart", "label": "Heart"},
            {"value": "truck", "label": "Truck"},
            {"value": "leaf", "label": "Leaf"}
          ],
          "default": "bee"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom Icon Image (overrides above)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Wild Himalayan Bees"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our bees forage in pristine alpine meadows at altitudes of 1500–3000m, collecting nectar from over 200 varieties of medicinal wildflowers."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Himachal Difference"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Why Our Honey is Different"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Not all honey is created equal. Here's what sets Himachal Valley apart."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFF3E0"
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "mountain",
            "title": "Himalayan Origin",
            "description": "Sourced from pristine alpine forests of Himachal Pradesh at elevations above 1500 metres, where pollution is zero and biodiversity is unmatched."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "bee",
            "title": "Wild Bee Colonies",
            "description": "Our bees are never fed sugar syrups. They forage freely on 200+ varieties of Himalayan wildflowers, medicinal herbs, and forest flora."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "lab",
            "title": "Lab Tested & FSSAI Certified",
            "description": "Every batch is independently tested for purity, HMF levels, moisture, and adulteration. Certificates available on request."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "leaf",
            "title": "Cold Extracted",
            "description": "We never heat our honey. Cold extraction preserves all live enzymes, antioxidants, pollen, and the natural goodness of raw honey."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "heart",
            "title": "Farmer First",
            "description": "We pay Himachali beekeepers 40% above market rate, ensuring sustainable livelihoods and ethical harvesting practices."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "truck",
            "title": "Fast Pan-India Delivery",
            "description": "Dispatched within 24 hours, delivered across all 28 states. Temperature-controlled packaging ensures freshness."
          }
        }
      ]
    }
  ]
}
{% endschema %}
