<section class="featured-products section-padding">
  <div class="container">
    <div class="section-header">
      {% if section.settings.eyebrow != blank %}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="section-title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    {% if section.settings.collection != blank %}
      {% assign featured_collection = collections[section.settings.collection] %}
      {% assign products_to_show = section.settings.products_to_show | default: 4 %}
      <div class="products-grid products-grid--{{ section.settings.columns }}">
        {% for product in featured_collection.products limit: products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
    {% else %}
      <div class="products-grid products-grid--4">
        {% for i in (1..4) %}
          <div class="product-card product-card--placeholder">
            <div class="product-card__media">
              <div class="product-card__placeholder-img">
                <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                  <ellipse cx="100" cy="120" rx="55" ry="65" fill="#F5C842" opacity="0.6"/>
                  <ellipse cx="100" cy="100" rx="45" ry="55" fill="#C8860A" opacity="0.8"/>
                  <rect x="85" y="55" width="30" height="20" rx="5" fill="#8B4513"/>
                </svg>
              </div>
            </div>
            <div class="product-card__info">
              <p class="product-card__vendor">Himachal Valley</p>
              <h3 class="product-card__title">Raw Himalayan Honey</h3>
              <p class="product-card__price">₹599</p>
              <button class="btn btn--primary btn--sm btn--full">Add to Cart</button>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <div class="section-cta">
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn--outline">
          {{ section.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Our Bestsellers"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Pure Honey, Straight from the Hive"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every jar tells the story of Himalayan wildflowers, patient bees, and generations of beekeeping wisdom."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Show"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products to Show",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        {"value": "2", "label": "2 Columns"},
        {"value": "3", "label": "3 Columns"},
        {"value": "4", "label": "4 Columns"}
      ],
      "default": "4"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
