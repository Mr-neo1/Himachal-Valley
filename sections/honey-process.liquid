<section class="honey-process section-padding" style="background: var(--color-dark);">
  <div class="container">
    <div class="section-header section-header--center section-header--light">
      {% if section.settings.eyebrow != blank %}
        <p class="section-eyebrow section-eyebrow--light">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="section-title section-title--light">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <p class="section-subtitle section-subtitle--light">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="process__steps">
      {% for block in section.blocks %}
        <div class="process__step" {{ block.shopify_attributes }}>
          <div class="process__step-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
          <div class="process__step-icon">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 120 }}" alt="{{ block.settings.title }}" loading="lazy">
            {% else %}
              {% case forloop.index %}
                {% when 1 %}
                  <img src="{{ 'honey_process_1.png' | asset_url }}" alt="Wild Bees Forage" loading="lazy" style="width:120px; height:120px; border-radius:50%; object-fit:cover; border:2px solid var(--color-accent);">
                {% when 2 %}
                  <img src="{{ 'honey_process_2.png' | asset_url }}" alt="Hive Maturation" loading="lazy" style="width:120px; height:120px; border-radius:50%; object-fit:cover; border:2px solid var(--color-accent);">
                {% when 3 %}
                  <img src="{{ 'honey_process_3.png' | asset_url }}" alt="Cold Extraction" loading="lazy" style="width:120px; height:120px; border-radius:50%; object-fit:cover; border:2px solid var(--color-accent);">
                {% when 4 %}
                  <img src="{{ 'honey_process_4.png' | asset_url }}" alt="Packed & Delivered" loading="lazy" style="width:120px; height:120px; border-radius:50%; object-fit:cover; border:2px solid var(--color-accent);">
              {% endcase %}
            {% endif %}
          <h3 class="process__step-title">{{ block.settings.title }}</h3>
          <p class="process__step-desc">{{ block.settings.description }}</p>
          {% unless forloop.last %}
            <div class="process__connector">
              <svg width="40" height="16" viewBox="0 0 40 16" fill="none"><path d="M0 8 L36 8" stroke="#C8860A" stroke-width="2" stroke-dasharray="4 3"/><polyline points="30,2 38,8 30,14" stroke="#C8860A" stroke-width="2" fill="none"/></svg>
            </div>
          {% endunless %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Honey Process",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Bees Collect Nectar"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Our bees fly up to 3km to collect nectar from pure Himalayan wildflowers."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From Hive to Home"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Journey of Your Honey"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every jar of Himachal Valley honey follows a sacred, time-honoured process."
    }
  ],
  "presets": [
    {
      "name": "Honey Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Wild Bees Forage",
            "description": "Our bees fly up to 3km across pristine Himalayan meadows collecting nectar from over 200 wildflower varieties."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Hive Maturation",
            "description": "The bees naturally convert nectar to honey inside the hive, a process we never rush. We wait until the comb is fully capped."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Cold Extraction",
            "description": "Frames are cold-spun below 37°C — body temperature — preserving every enzyme, antioxidant, and pollen grain."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Packed & Delivered",
            "description": "Filled into food-grade glass jars, sealed, lab-tested, and dispatched to your doorstep within 24 hours."
          }
        }
      ]
    }
  ]
}
{% endschema %}
