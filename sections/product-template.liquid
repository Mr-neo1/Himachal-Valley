<div class="product-page section-padding">
  <div class="container">
    <div class="product-page__grid">

      <!-- Media Gallery -->
      <div class="product-page__gallery">
        <div class="product-gallery">
          <div class="product-gallery__thumbnails">
            {% for image in product.images %}
              <button
                class="gallery-thumb {% if forloop.first %}gallery-thumb--active{% endif %}"
                data-index="{{ forloop.index0 }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="120"
                  height="120"
                >
              </button>
            {% endfor %}
          </div>

          <div class="product-gallery__main">
            {% for image in product.images %}
              <div class="gallery-slide {% if forloop.first %}gallery-slide--active{% endif %}" data-index="{{ forloop.index0 }}">
                <img
                  src="{{ image | image_url: width: 800 }}"
                  srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1000 }} 1000w"
                  sizes="(max-width: 768px) 100vw, 50vw"
                  alt="{{ image.alt | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="800"
                  height="800"
                >
              </div>
            {% else %}
              <div class="gallery-slide gallery-slide--active">
                <div class="product-gallery__placeholder">
                  <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" width="100%">
                    <rect width="400" height="400" fill="#FFF8F0"/>
                    <ellipse cx="200" cy="240" rx="110" ry="130" fill="#F5C842" opacity="0.5"/>
                    <ellipse cx="200" cy="200" rx="90" ry="110" fill="#C8860A" opacity="0.7"/>
                    <rect x="170" y="110" width="60" height="40" rx="10" fill="#8B4513"/>
                    <rect x="180" y="95" width="40" height="20" rx="5" fill="#6B8E5E"/>
                  </svg>
                </div>
              </div>
            {% endfor %}

            {% if product.images.size > 1 %}
              <button class="gallery-nav gallery-nav--prev" aria-label="Previous image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="gallery-nav gallery-nav--next" aria-label="Next image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            {% endif %}
          </div>
        </div>

        <!-- Product Badges -->
        <div class="product-page__trust-badges">
          <div class="product-trust-badge">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>100% Pure</span>
          </div>
          <div class="product-trust-badge">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85"/></svg>
            <span>FSSAI Certified</span>
          </div>
          <div class="product-trust-badge">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Free Shipping ₹999+</span>
          </div>
          <div class="product-trust-badge">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            <span>Lab Tested</span>
          </div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-page__info">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span>/</span>
          <a href="{{ routes.all_products_collection_url }}">Shop</a>
          <span>/</span>
          <span>{{ product.title }}</span>
        </nav>

        {% if product.vendor != blank %}
          <p class="product-page__vendor">{{ product.vendor }}</p>
        {% endif %}

        <h1 class="product-page__title">{{ product.title }}</h1>

        <!-- Rating -->
        {% if product.metafields.reviews.rating.value %}
          <div class="product-page__rating">
            {% assign rating = product.metafields.reviews.rating.value | times: 1 %}
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" {% if i <= rating %}fill="#F5C842"{% else %}fill="#DDD"{% endif %}><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% endfor %}
            <span>({{ product.metafields.reviews.rating_count.value }} reviews)</span>
          </div>
        {% endif %}

        <!-- Price -->
        <div class="product-page__price-wrap">
          {% if product.compare_at_price > product.price %}
            <span class="product-page__price product-page__price--sale">{{ product.price | money }}</span>
            <span class="product-page__price product-page__price--compare">{{ product.compare_at_price | money }}</span>
            {% assign saving = product.compare_at_price | minus: product.price %}
            <span class="product-page__saving">You save {{ saving | money }}</span>
          {% else %}
            <span class="product-page__price">{{ product.price | money }}</span>
          {% endif %}
          <span class="product-page__tax-note">Inclusive of all taxes</span>
        </div>

        <!-- Short Description -->
        {% if product.metafields.custom.short_description != blank %}
          <p class="product-page__short-desc">{{ product.metafields.custom.short_description }}</p>
        {% endif %}

        {% form 'product', product, id: 'product-form', data-type: 'add-to-cart-form' %}
          <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

          <!-- Variants -->
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              <div class="product-option">
                <label class="product-option__label">
                  {{ option.name }}
                  {% if option.name == 'Weight' or option.name == 'Size' %}
                    <span class="product-option__selected" id="selected-{{ option.name | handleize }}">
                      : {{ option.selected_value }}
                    </span>
                  {% endif %}
                </label>
                <div class="product-option__values">
                  {% for value in option.values %}
                    <button
                      type="button"
                      class="option-btn {% if option.selected_value == value %}option-btn--active{% endif %}"
                      data-option="{{ option.position }}"
                      data-value="{{ value }}"
                    >
                      {{ value }}
                    </button>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          {% endunless %}

          <!-- Quantity -->
          <div class="product-quantity">
            <label class="product-option__label">Quantity</label>
            <div class="quantity-selector">
              <button type="button" class="quantity-btn" data-action="decrease" aria-label="Decrease quantity">−</button>
              <input type="number" name="quantity" id="quantity" value="1" min="1" max="99" class="quantity-input" aria-label="Quantity">
              <button type="button" class="quantity-btn" data-action="increase" aria-label="Increase quantity">+</button>
            </div>
          </div>

          <!-- CTA Buttons -->
          <div class="product-page__cta">
            <button
              type="submit"
              class="btn btn--primary btn--lg product-page__atc"
              {% unless product.available %}disabled{% endunless %}
            >
              {% if product.available %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                Add to Cart
              {% else %}
                Sold Out
              {% endif %}
            </button>
            {% if product.available %}
              <a
                href="/checkout?{% for variant in product.variants %}{% if variant.id == product.selected_or_first_available_variant.id %}id={{ variant.id }}:1{% endif %}{% endfor %}"
                class="btn btn--dark btn--lg product-page__buy-now"
              >
                Buy Now
              </a>
            {% endif %}
          </div>
        {% endform %}

        <!-- Product Highlights -->
        {% if section.settings.show_highlights %}
          <div class="product-page__highlights">
            <div class="product-highlight">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Hand-harvested from Himalayan apiaries</span>
            </div>
            <div class="product-highlight">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Never heated above 37°C — enzyme-rich</span>
            </div>
            <div class="product-highlight">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <span>No sugar, no adulteration, no preservatives</span>
            </div>
            <div class="product-highlight">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <span>FSSAI license: 10019022000246</span>
            </div>
          </div>
        {% endif %}

        <!-- Description Tabs -->
        <div class="product-tabs">
          <div class="product-tabs__nav">
            <button class="tab-btn tab-btn--active" data-tab="description">Description</button>
            <button class="tab-btn" data-tab="benefits">Benefits</button>
            <button class="tab-btn" data-tab="how-to-use">How to Use</button>
          </div>

          <div class="tab-panel tab-panel--active" id="tab-description">
            <div class="rte">{{ product.description }}</div>
          </div>

          <div class="tab-panel" id="tab-benefits">
            <div class="rte">
              {% if product.metafields.custom.benefits != blank %}
                {{ product.metafields.custom.benefits }}
              {% else %}
                <ul>
                  <li>Rich in antioxidants that fight free radicals</li>
                  <li>Natural antibacterial properties</li>
                  <li>Boosts immunity and energy levels</li>
                  <li>Soothes sore throat and cough</li>
                  <li>Better sleep quality when taken with warm milk</li>
                  <li>Helps in wound healing and skin nourishment</li>
                </ul>
              {% endif %}
            </div>
          </div>

          <div class="tab-panel" id="tab-how-to-use">
            <div class="rte">
              {% if product.metafields.custom.how_to_use != blank %}
                {{ product.metafields.custom.how_to_use }}
              {% else %}
                <ul>
                  <li>Take 1–2 teaspoons daily on an empty stomach with warm water</li>
                  <li>Add to your morning tea or coffee (don't boil)</li>
                  <li>Use as a natural sweetener in desserts and baking</li>
                  <li>Apply topically on skin as a natural moisturizer</li>
                  <li>Mix with turmeric and ginger for an immunity shot</li>
                </ul>
                <p><strong>Note:</strong> Do not give honey to children under 12 months. Store at room temperature away from direct sunlight.</p>
              {% endif %}
            </div>
          </div>
        </div>

        <!-- Share -->
        <div class="product-page__share">
          <span>Share:</span>
          <a href="https://wa.me/?text={{ product.title | url_encode }}%20{{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" aria-label="Share on WhatsApp" class="share-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" aria-label="Share on Facebook" class="share-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {% if section.settings.show_related and recommendations.products_count > 0 %}
      <div class="product-page__related section-padding">
        <div class="section-header">
          <p class="section-eyebrow">You May Also Love</p>
          <h2 class="section-title">Related Products</h2>
        </div>
        <div class="products-grid products-grid--4">
          {% for product in recommendations.products limit: 4 %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</div>

<script>
  // Product gallery
  document.addEventListener('DOMContentLoaded', function() {
    const thumbs = document.querySelectorAll('.gallery-thumb');
    const slides = document.querySelectorAll('.gallery-slide');
    let current = 0;

    function goTo(index) {
      thumbs[current]?.classList.remove('gallery-thumb--active');
      slides[current]?.classList.remove('gallery-slide--active');
      current = index;
      thumbs[current]?.classList.add('gallery-thumb--active');
      slides[current]?.classList.add('gallery-slide--active');
    }

    thumbs.forEach((thumb, i) => thumb.addEventListener('click', () => goTo(i)));

    document.querySelector('.gallery-nav--prev')?.addEventListener('click', () => {
      goTo(current === 0 ? slides.length - 1 : current - 1);
    });
    document.querySelector('.gallery-nav--next')?.addEventListener('click', () => {
      goTo(current === slides.length - 1 ? 0 : current + 1);
    });

    // Tabs
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('tab-btn--active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('tab-panel--active'));
        this.classList.add('tab-btn--active');
        document.getElementById('tab-' + this.dataset.tab)?.classList.add('tab-panel--active');
      });
    });

    // Quantity
    document.querySelectorAll('.quantity-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const input = document.getElementById('quantity');
        const val = parseInt(input.value) || 1;
        input.value = this.dataset.action === 'increase' ? val + 1 : Math.max(1, val - 1);
      });
    });

    // Option buttons
    document.querySelectorAll('.option-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const parent = this.closest('.product-option');
        parent.querySelectorAll('.option-btn').forEach(b => b.classList.remove('option-btn--active'));
        this.classList.add('option-btn--active');

        const label = parent.querySelector('[id^="selected-"]');
        if (label) label.textContent = ': ' + this.dataset.value;

        updateVariant();
      });
    });

    function updateVariant() {
      const selected = {};
      document.querySelectorAll('.product-option').forEach(opt => {
        const active = opt.querySelector('.option-btn--active');
        if (active) selected[active.dataset.option] = active.dataset.value;
      });
      // In real Shopify, would match against product.variants JSON
    }
  });
</script>

{% schema %}
{
  "name": "Product Template",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_highlights",
      "label": "Show Product Highlights",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Show Related Products",
      "default": true
    }
  ]
}
{% endschema %}
