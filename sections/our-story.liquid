<section class="our-story section-padding">
  <div class="container">
    <div class="our-story__grid">
      <div class="our-story__media">
        {% if section.settings.image %}
          <div class="our-story__img-wrap">
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              alt="{{ section.settings.image.alt | escape }}"
              class="our-story__img"
              loading="lazy"
            >
          </div>
        {% else %}
          <div class="our-story__img-wrap">
            <img
              src="{{ 'our_story_1.png' | asset_url }}"
              alt="Himachal Valley Beekeeper"
              class="our-story__img"
              loading="lazy"
            >
          </div>
        {% endif %}

        <div class="our-story__stat-card">
          <span class="our-story__stat-number">{{ section.settings.stat_number | default: '10+' }}</span>
          <span class="our-story__stat-label">{{ section.settings.stat_label | default: 'Years of Experience' }}</span>
        </div>
      </div>

      <div class="our-story__content">
        {% if section.settings.eyebrow != blank %}
          <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <div class="our-story__body rte">
          {{ section.settings.content }}
        </div>
        <div class="our-story__highlights">
          {% for block in section.blocks %}
            <div class="our-story__highlight" {{ block.shopify_attributes }}>
              <div class="our-story__highlight-dot"></div>
              <p>{{ block.settings.text }}</p>
            </div>
          {% endfor %}
        </div>
        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="btn btn--primary">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Our Story",
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight Point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Highlight Text",
          "default": "Hand-harvested by local Himachali farmers"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"

    },
    {
      "type": "text",
      "id": "stat_number",
      "label": "Stat Number",
      "default": "10+"
    },
    {
      "type": "text",
      "id": "stat_label",
      "label": "Stat Label",
      "default": "Years of Experience"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Our Story"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Born in the Valleys, Raised by the Mountains"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Nestled in the pristine valleys of Himachal Pradesh, our story begins with a deep love for the mountains and their gifts. Three generations of our family have tended to beehives in the untouched forests of Kangra and Kullu, where wildflowers bloom in abundance and the air is pure.</p><p>We believe honey should be exactly as nature intended — raw, unfiltered, and alive with enzymes, antioxidants, and the unique terroir of the Himalayas.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Read Our Full Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Our Story",
      "blocks": [
        {"type": "highlight", "settings": {"text": "Hand-harvested by local Himachali farmers"}},
        {"type": "highlight", "settings": {"text": "Cold-extracted to preserve all natural enzymes"}},
        {"type": "highlight", "settings": {"text": "Zero heating, zero filtering, zero compromises"}},
        {"type": "highlight", "settings": {"text": "FSSAI certified and lab-tested for purity"}}
      ]
    }
  ]
}
{% endschema %}
