<section class="trust-bar">
  <div class="container">
    <div class="trust-bar__grid">
      {% for block in section.blocks %}
        <div class="trust-bar__item" {{ block.shopify_attributes }}>
          <div class="trust-bar__icon">
            {% case block.settings.icon %}
              {% when 'shield' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {% when 'leaf' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
              {% when 'truck' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {% when 'award' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
              {% when 'globe' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/></svg>
              {% else %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {% endcase %}
          </div>
          <div class="trust-bar__text">
            <h4 class="trust-bar__title">{{ block.settings.title }}</h4>
            <p class="trust-bar__desc">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {"value": "shield", "label": "Shield"},
            {"value": "leaf", "label": "Leaf"},
            {"value": "truck", "label": "Truck"},
            {"value": "award", "label": "Award"},
            {"value": "globe", "label": "Globe"}
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Pure"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "No additives, preservatives or artificial flavours"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "title": "100% Pure & Raw",
            "description": "No heating, no filtering, no additives"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "leaf",
            "title": "Naturally Organic",
            "description": "Sourced from pristine Himalayan forests"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "truck",
            "title": "Free Shipping",
            "description": "On all orders above ₹999 across India"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "award",
            "title": "Lab Tested",
            "description": "FSSAI certified, quality guaranteed"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "globe",
            "title": "Direct from Farmers",
            "description": "Supporting local Himachali beekeepers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
