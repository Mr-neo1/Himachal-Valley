<header class="site-header" id="site-header">
  <div class="container">
    <div class="site-header__inner">

      <!-- Hamburger (Mobile) -->
      <button class="site-header__hamburger" id="mobile-menu-toggle" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <!-- Logo -->
      <div class="site-header__logo">
        <a href="/" class="site-header__logo-link">
          {% if section.settings.logo %}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="site-header__logo-img">
          {% else %}
            <div class="site-header__logo-text">
              <span class="logo-main">Himachal Valley</span>
              <span class="logo-sub">Pure Mountain Honey</span>
            </div>
          {% endif %}
        </a>
      </div>

      <!-- Nav (Desktop) -->
      <nav class="site-header__nav" aria-label="Primary">
        <ul class="site-header__nav-list">
          <li><a href="/collections/all" class="nav-link">Shop All</a></li>
          <li class="has-dropdown">
            <a href="/collections" class="nav-link">Collections <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></a>
            <div class="nav-dropdown">
              <a href="/collections/raw-honey">Raw Honey</a>
              <a href="/collections/multifloral-honey">Multifloral Honey</a>
              <a href="/collections/flavored-honey">Infused Honey</a>
              <a href="/collections/gift-sets">Gift Sets</a>
            </div>
          </li>
          <li><a href="/pages/our-story" class="nav-link">Our Story</a></li>
          <li><a href="/pages/faq" class="nav-link">FAQ</a></li>
          <li><a href="/pages/contact" class="nav-link">Contact</a></li>
        </ul>
      </nav>

      <!-- Icons -->
      <div class="site-header__icons">
        <button class="site-header__icon" id="search-toggle" aria-label="Search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </button>
        <a href="/account" class="site-header__icon" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
        <button class="site-header__icon site-header__cart" id="cart-toggle" aria-label="Cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 01-8 0"></path></svg>
          <span class="cart-count" id="cart-count" style="display:none;">0</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Search Bar -->
  <div class="search-bar" id="search-bar" aria-hidden="true">
    <div class="container">
      <form action="/search" method="get" role="search" class="search-bar__form">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="search" name="q" placeholder="Search for honey, gift sets..." class="search-bar__input" autocomplete="off">
        <button type="button" id="search-close" aria-label="Close search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </form>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 160
    }
  ]
}
{% endschema %}
