<footer class="site-footer">
  <div class="site-footer__main">
    <div class="container">
      <div class="site-footer__grid">

        <!-- Brand Column -->
        <div class="site-footer__col site-footer__col--brand">
          <div class="site-footer__logo">
            <span class="logo-main">Himachal Valley</span>
            <span class="logo-sub">Pure Mountain Honey</span>
          </div>
          <p class="site-footer__tagline">{{ section.settings.tagline | default: 'Bringing the purity of the Himalayas to every Indian home, one golden jar at a time.' }}</p>
          <div class="site-footer__social">
            {% if settings.social_instagram != blank %}
              <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
            {% endif %}
            {% if settings.social_facebook != blank %}
              <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            {% endif %}
            {% if settings.social_youtube != blank %}
              <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
              </a>
            {% endif %}
          </div>
          <div class="site-footer__certifications">
            <div class="cert-badge">FSSAI</div>
            <div class="cert-badge">ISO</div>
            <div class="cert-badge">Lab<br>Tested</div>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">Shop</h4>
          <ul class="site-footer__links">
            <li><a href="/collections/all">All Products</a></li>
            <li><a href="/collections/raw-honey">Raw Honey</a></li>
            <li><a href="/collections/multifloral-honey">Multifloral Honey</a></li>
            <li><a href="/collections/flavored-honey">Infused Honey</a></li>
            <li><a href="/collections/gift-sets">Gift Sets</a></li>
            <li><a href="/collections/bulk-orders">Bulk Orders</a></li>
          </ul>
        </div>

        <!-- Company -->
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">Company</h4>
          <ul class="site-footer__links">
            <li><a href="/pages/our-story">Our Story</a></li>
            <li><a href="/pages/beekeeping">Our Beekeeping</a></li>
            <li><a href="/pages/quality">Quality & Testing</a></li>
            <li><a href="/blogs/news">Blog</a></li>
            <li><a href="/pages/wholesale">Wholesale</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          </ul>
        </div>

        <!-- Help -->
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">Help</h4>
          <ul class="site-footer__links">
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/shipping">Shipping Policy</a></li>
            <li><a href="/pages/returns">Returns & Refunds</a></li>
            <li><a href="/pages/privacy">Privacy Policy</a></li>
            <li><a href="/pages/terms">Terms of Service</a></li>
            <li><a href="/account">My Account</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">Get in Touch</h4>
          <ul class="site-footer__contact">
            {% if section.settings.phone != blank %}
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.61 5.61l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a>
              </li>
            {% endif %}
            {% if section.settings.email != blank %}
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
              </li>
            {% endif %}
            {% if section.settings.address != blank %}
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>{{ section.settings.address }}</span>
              </li>
            {% endif %}
          </ul>
          <div class="site-footer__payment">
            <p>We Accept</p>
            <div class="payment-icons">
              <span class="payment-icon">UPI</span>
              <span class="payment-icon">GPay</span>
              <span class="payment-icon">PhonePe</span>
              <span class="payment-icon">Cards</span>
              <span class="payment-icon">COD</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container">
      <div class="site-footer__bottom-inner">
        <p>&copy; {{ 'now' | date: '%Y' }} Himachal Valley. All rights reserved. Made with ❤️ in Himachal Pradesh, India.</p>
        <div class="site-footer__bottom-links">
          <a href="/pages/privacy">Privacy</a>
          <a href="/pages/terms">Terms</a>
          <a href="/pages/sitemap">Sitemap</a>
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand Tagline",
      "default": "Bringing the purity of the Himalayas to every Indian home, one golden jar at a time."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+91 98765 43210"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "hello@himachalvalley.in"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "Palampur, Himachal Pradesh — 176061"
    }
  ]
}
{% endschema %}
