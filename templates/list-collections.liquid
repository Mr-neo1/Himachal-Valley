<section class="collections-list section-padding">
  <div class="container">
    <div class="section-header section-header--center">
      <p class="section-eyebrow">Explore</p>
      <h1 class="section-title">Our Collections</h1>
      <p class="section-subtitle">Discover the finest honey varieties sourced from the pristine valleys of Himachal Pradesh.</p>
    </div>

    <div class="collections-grid">
      {% for collection in collections %}
        {% unless collection.handle == 'frontpage' or collection.handle == 'all' %}
          <a href="{{ collection.url }}" class="collection-card">
            <div class="collection-card__media">
              {% if collection.image %}
                <img
                  src="{{ collection.image | image_url: width: 600 }}"
                  alt="{{ collection.title | escape }}"
                  class="collection-card__img"
                  loading="lazy"
                >
              {% else %}
                <div class="collection-card__placeholder">
                  <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" width="80" height="80">
                    <ellipse cx="100" cy="120" rx="55" ry="65" fill="#F5C842" opacity="0.4"/>
                    <ellipse cx="100" cy="100" rx="45" ry="55" fill="#C8860A" opacity="0.5"/>
                    <rect x="85" y="55" width="30" height="20" rx="5" fill="#8B4513"/>
                  </svg>
                </div>
              {% endif %}
              <div class="collection-card__overlay"></div>
            </div>
            <div class="collection-card__content">
              <h2 class="collection-card__title">{{ collection.title }}</h2>
              <p class="collection-card__count">{{ collection.products_count }} Products</p>
              <span class="collection-card__link">Shop Now →</span>
            </div>
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.collections-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}
@media (min-width: 768px) {
  .collections-grid { grid-template-columns: repeat(3, 1fr); }
}

.collection-card {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--color-dark);
  transition: transform var(--transition), box-shadow var(--transition);
}
.collection-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}

.collection-card__media {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
}
.collection-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}
.collection-card:hover .collection-card__img {
  transform: scale(1.08);
}
.collection-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2C1A0E 0%, #5C3A1E 50%, #C8860A 100%);
}
.collection-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(26,17,10,0.85) 0%, rgba(26,17,10,0.1) 60%, transparent 100%);
}

.collection-card__content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 28px;
  z-index: 1;
}
.collection-card__title {
  font-size: 1.3rem;
  font-weight: 700;
  color: white;
  margin-bottom: 4px;
}
.collection-card__count {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.6);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 12px;
}
.collection-card__link {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-accent);
  transition: letter-spacing var(--transition);
}
.collection-card:hover .collection-card__link {
  letter-spacing: 0.05em;
}
</style>
