<div class="cart-page section-padding">
  <div class="container">
    <h1 class="cart-page__title">Your Cart</h1>

    {% if cart.item_count == 0 %}
      <div class="cart-empty">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <h2>Your cart is empty</h2>
        <p>Looks like you haven't added any honey yet.</p>
        <a href="/collections/all" class="btn btn--primary btn--lg">Shop Pure Honey</a>
      </div>
    {% else %}
      <div class="cart-layout">
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-row">
              <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title }}" class="cart-row__img" loading="lazy">
              <div class="cart-row__info">
                <a href="{{ item.url }}" class="cart-row__title">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}
                  <p class="cart-row__variant">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="cart-row__price">{{ item.price | money }}</p>
              </div>
              <div class="cart-row__qty quantity-selector">
                <button class="quantity-btn" onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.dispatchEvent(new Event('change'))">−</button>
                <input
                  type="number"
                  name="updates[{{ item.key }}]"
                  value="{{ item.quantity }}"
                  min="0"
                  max="99"
                  class="quantity-input"
                  data-key="{{ item.key }}"
                  onchange="updateCartLine(this)"
                >
                <button class="quantity-btn" onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.dispatchEvent(new Event('change'))">+</button>
              </div>
              <p class="cart-row__total">{{ item.line_price | money }}</p>
              <a href="/cart/change?id={{ item.key }}&quantity=0" class="cart-row__remove">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </a>
            </div>
          {% endfor %}
        </div>

        <div class="cart-summary">
          <div class="cart-summary__inner">
            <h3 class="cart-summary__title">Order Summary</h3>

            <div class="cart-summary__line">
              <span>Subtotal ({{ cart.item_count }} items)</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-summary__line">
              <span>Shipping</span>
              <span>{% if cart.total_price >= 99900 %}Free{% else %}Calculated at checkout{% endif %}</span>
            </div>

            {% if cart.total_price < 99900 %}
              <div class="cart-free-shipping">
                {% assign remaining = 99900 | minus: cart.total_price %}
                <p>Add {{ remaining | money }} more for <strong>FREE shipping!</strong></p>
                <div class="cart-progress">
                  <div class="cart-progress__fill" style="width: {{ cart.total_price | times: 100 | divided_by: 99900 }}%"></div>
                </div>
              </div>
            {% else %}
              <div class="cart-free-shipping cart-free-shipping--achieved">
                <p>🎉 You've unlocked free shipping!</p>
              </div>
            {% endif %}

            <div class="cart-summary__total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <p class="cart-summary__tax-note">Taxes included. Shipping calculated at checkout.</p>

            <a href="/checkout" class="btn btn--primary btn--full btn--lg">Proceed to Checkout</a>
            <a href="/collections/all" class="btn btn--outline btn--full" style="margin-top:12px;">Continue Shopping</a>

            <div class="cart-summary__trust">
              <div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>Secure Checkout</span>
              </div>
              <div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/></svg>
                <span>Fast Delivery</span>
              </div>
              <div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span>24/7 Support</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
.cart-page__title { font-size: clamp(24px, 3vw, 40px); margin-bottom: 32px; color: var(--color-dark); }
.cart-empty { text-align: center; padding: 64px 24px; display: flex; flex-direction: column; align-items: center; gap: 16px; }
.cart-empty h2 { font-size: 1.6rem; color: var(--color-dark); }
.cart-empty p { color: var(--color-text-light); }
.cart-layout { display: grid; gap: 32px; }
@media(min-width:1024px) { .cart-layout { grid-template-columns: 1fr 380px; align-items: start; } }
.cart-items { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--color-border); border-radius: var(--radius-xl); overflow: hidden; }
.cart-row { display: flex; align-items: center; gap: 16px; padding: 20px 24px; border-bottom: 1px solid var(--color-border); flex-wrap: wrap; }
.cart-row:last-child { border-bottom: none; }
.cart-row__img { width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius-md); background: var(--color-background); flex-shrink: 0; }
.cart-row__info { flex: 1; min-width: 140px; }
.cart-row__title { font-size: 0.95rem; font-weight: 600; color: var(--color-dark); margin-bottom: 4px; display: block; }
.cart-row__title:hover { color: var(--color-primary); }
.cart-row__variant { font-size: 0.8rem; color: var(--color-text-light); margin-bottom: 4px; }
.cart-row__price { font-size: 0.85rem; color: var(--color-text-light); }
.cart-row__total { font-weight: 700; color: var(--color-primary); font-size: 1rem; min-width: 80px; text-align: right; }
.cart-row__remove { color: var(--color-text-light); transition: color var(--transition); }
.cart-row__remove:hover { color: #c00; }
.cart-summary__inner { background: white; border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 28px; position: sticky; top: calc(var(--header-height) + 24px); }
.cart-summary__title { font-size: 1.15rem; margin-bottom: 20px; color: var(--color-dark); }
.cart-summary__line { display: flex; justify-content: space-between; font-size: 0.9rem; color: var(--color-text-light); margin-bottom: 12px; }
.cart-free-shipping { background: rgba(200,134,10,0.06); border: 1px dashed rgba(200,134,10,0.4); border-radius: var(--radius-md); padding: 12px 14px; margin: 16px 0; font-size: 0.85rem; }
.cart-free-shipping p { color: var(--color-text); }
.cart-free-shipping--achieved p { color: var(--color-success); font-weight: 600; }
.cart-progress { height: 6px; background: var(--color-border); border-radius: 3px; margin-top: 8px; overflow: hidden; }
.cart-progress__fill { height: 100%; background: var(--color-primary); border-radius: 3px; transition: width 0.5s ease; }
.cart-summary__total { display: flex; justify-content: space-between; font-size: 1.1rem; font-weight: 700; color: var(--color-dark); margin: 16px 0 4px; padding-top: 16px; border-top: 1px solid var(--color-border); }
.cart-summary__tax-note { font-size: 0.75rem; color: var(--color-text-light); margin-bottom: 20px; }
.cart-summary__trust { display: flex; flex-direction: column; gap: 8px; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--color-border); }
.cart-summary__trust > div { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: var(--color-text-light); }
.cart-summary__trust svg { color: var(--color-primary); flex-shrink: 0; }
</style>

<script>
function updateCartLine(input) {
  const key = input.dataset.key;
  const qty = parseInt(input.value) || 0;
  fetch('/cart/change.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: key, quantity: qty })
  }).then(() => window.location.reload());
}
</script>
